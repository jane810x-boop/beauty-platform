# ========================================
# F&J Beauty Platform - Environment Config
# ========================================
# Copy this file to .env and fill in your values

# Server
PORT=3001
NODE_ENV=development

# JWT Secret (generate a random 64-char string)
JWT_SECRET=change_this_to_a_random_64_character_string

# Domain
DOMAIN=http://localhost:3001

# Stripe Payment Keys (test mode)
# Get from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxx

# PayPal Client ID (sandbox)
# Get from https://developer.paypal.com
PAYPAL_CLIENT_ID=sandbox_client_id
PAYPAL_CLIENT_SECRET=sandbox_secret

# WhatsApp Business Number (international, no + or spaces)
WA_NUMBER=1234567890
WA_NAME=F&J Support

# Admin
ADMIN_EMAIL=admin@fjbeauty.com

# Email SMTP (for order confirmations, welcome emails, cart abandonment)
# Gmail: smtp.gmail.com / 587 / use App Password
# SendGrid: smtp.sendgrid.net / 587 / apikey as password
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@email.com
SMTP_PASS=your-app-password
EMAIL_FROM_NAME=F&J Beauty
EMAIL_FROM=no-reply@fjbeauty.com

# Production checklist:
# 1. Set NODE_ENV=production
# 2. Set DOMAIN=https://fjbeauty.com
# 3. Generate a strong JWT_SECRET
# 4. Replace Stripe keys with live keys
# 5. Configure SMTP with real credentials
# 6. Set PayPal to live client ID
